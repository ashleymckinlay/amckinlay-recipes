<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Uploads pgAdmin 4 pkg to Jamf Pro and creates a policy for deployment.</string>
	<key>Identifier</key>
	<string>com.github.ashleymckinlay.jamf.pgAdmin4</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>pgAdmin4</string>
		<key>JAMF_URL</key>
		<string>https://jamf.example.com</string>
		<key>JAMF_USER</key>
		<string>autopkg</string>
		<key>JAMF_PASS</key>
		<string></string>
		<key>CATEGORY</key>
		<string>Databases</string>
		<key>POLICY_CATEGORY</key>
		<string>Databases</string>
		<key>POLICY_TEMPLATE</key>
		<string>%RECIPE_DIR%/PolicyTemplate.xml</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>ParentRecipe</key>
	<string>com.github.ashleymckinlay.pkg.pgAdmin4</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>JamfPackageUploader</string>
			<key>Arguments</key>
			<dict>
				<key>pkg_path</key>
				<string>%pkg_path%</string>
				<key>prod_name</key>
				<string>%NAME%</string>
				<key>category</key>
				<string>%CATEGORY%</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>JamfPolicyUploader</string>
			<key>Arguments</key>
			<dict>
				<key>policy_template</key>
				<string>%POLICY_TEMPLATE%</string>
				<key>policy_name</key>
				<string>%NAME% - Install Latest</string>
				<key>category</key>
				<string>%POLICY_CATEGORY%</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
