<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest version of pgAdmin 4 for macOS (universal - Intel and Apple Silicon compatible).</string>
	<key>Identifier</key>
	<string>com.github.ashleymckinlay.download.pgAdmin4</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>pgAdmin4</string>
		<key>BASE_URL</key>
		<string>https://www.postgresql.org/ftp/pgadmin/pgadmin4</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%BASE_URL%/</string>
				<key>re_pattern</key>
				<string>v(\d+\.\d+)</string>
				<key>request_headers</key>
				<dict>
					<key>User-Agent</key>
					<string>AutoPkg</string>
				</dict>
				<key>result_output_var_name</key>
				<string>latest_version</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%BASE_URL%/v%latest_version%/macos/</string>
				<key>re_pattern</key>
				<string>pgadmin4-%latest_version%-x64\.dmg</string>
				<key>request_headers</key>
				<dict>
					<key>User-Agent</key>
					<string>AutoPkg</string>
				</dict>
				<key>result_output_var_name</key>
				<string>filename_x64</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%BASE_URL%/v%latest_version%/macos/%filename_x64%</string>
				<key>filename</key>
				<string>%NAME%-latest-x64.dmg</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%BASE_URL%/v%latest_version%/macos/pgadmin4-%latest_version%-arm64.dmg</string>
				<key>filename</key>
				<string>%NAME%-latest-arm64.dmg</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
	</array>
</dict>
</plist>
