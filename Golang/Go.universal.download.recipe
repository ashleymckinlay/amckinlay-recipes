<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest Go language binary from https://go.dev/dl/ for the current system architecture (universal - auto-detects)</string>
	<key>Identifier</key>
	<string>com.github.ashleymckinlay.download.golang.universal</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Go</string>
		<key>OS_VERSION</key>
		<string>darwin</string>
		<key>ARCH</key>
		<string>universal</string>
		<key>DOWNLOAD_URL</key>
		<string>https://go.dev/dl/</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3.1</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>GoDownloadProcessor</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%DOWNLOAD_URL%</string>
				<key>os_version</key>
				<string>%OS_VERSION%</string>
				<key>arch</key>
				<string>%ARCH%</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%go_url%</string>
				<key>filename</key>
				<string>%filename%</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>CodeSignatureVerifier</string>
			<key>Arguments</key>
			<dict>
				<key>input_path</key>
				<string>%pathname%</string>
				<key>requirement</key>
				<string>identifier "com.google" and anchor apple generic and certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */ and certificate leaf[subject.OU] = UVG73ZN435</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
