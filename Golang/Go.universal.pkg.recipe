<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Creates a universal macOS installer package for Go language (auto-detects architecture)</string>
	<key>Identifier</key>
	<string>com.github.ashleymckinlay.pkg.golang.universal</string>
	<key>ParentRecipe</key>
	<string>com.github.ashleymckinlay.download.golang.universal</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Go</string>
		<key>PKG_ID</key>
		<string>com.google.go</string>
		<key>INSTALL_PATH</key>
		<string>/usr/local</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3.1</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>PkgRootCreator</string>
			<key>Arguments</key>
			<dict>
				<key>pkgroot</key>
				<string>%RECIPE_CACHE_DIR%/pkgroot</string>
				<key>pkgdirs</key>
				<array>
					<string>usr/local</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>Unarchiver</string>
			<key>Arguments</key>
			<dict>
				<key>archive_path</key>
				<string>%pathname%</string>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/pkgroot/usr/local</string>
				<key>purge_destination</key>
				<true/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PkgCreator</string>
			<key>Arguments</key>
			<dict>
				<key>pkg_root</key>
				<string>%RECIPE_CACHE_DIR%/pkgroot</string>
				<key>scripts</key>
				<string>%RECIPE_DIR%/scripts</string>
				<key>pkg_name</key>
				<string>%NAME%-%go_version%</string>
				<key>pkg_output_filename</key>
				<string>%NAME%-%go_version%.pkg</string>
				<key>identifier</key>
				<string>%PKG_ID%</string>
				<key>version</key>
				<string>%go_version%</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PathDeleter</string>
			<key>Arguments</key>
			<dict>
				<key>path_list</key>
				<array>
					<string>%RECIPE_CACHE_DIR%/pkgroot</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
